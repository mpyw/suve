# Supply-chain hardening: refuse to resolve any package version published less
# than 7 days ago. A compromised release is usually yanked within days, so this
# window keeps `npm install` / `npm update` from ever pulling a brand-new
# malicious version. Requires npm >= 11 (bundled with Node 24, pinned in
# ../../../mise.toml); older npm silently ignores this key.
#
# `npm ci` is unaffected — it installs exactly what package-lock.json pins, so
# this only gates version *resolution*. Dependabot's cooldown (see
# ../../../.github/dependabot.yml) enforces the same 7-day age on bump PRs.
min-release-age=7
